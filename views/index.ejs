        <!-- MAIN CONTENT -->
        <div class="col-lg-9">
          <!-- TRENDING SECTION -->
          <div class="movies-section">
            <div class="section-header">
              <h2 class="section-title">🔥 Trending</h2>
             <a href="/trending" class="btn btn-sm btn-outline-accent view-all-btn">View All</a>
            </div>
            <div class="row g-2">
              <% if (locals.trending) { %>
                <% trending.slice(0, 12).forEach(file => { %>
                  <div class="col-6 col-sm-4 col-lg-3">
                    <%- include('partials/movie-card', { file, botUsername }) %>
